{
  // ── Global model defaults (used by PM mode for agent tiers) ──
  "pm_model": "sonnet",           // Model for the PM orchestrator
  "opus_model": "opus",           // Default model for opus-tier agents
  "sonnet_model": "sonnet",       // Default model for sonnet-tier agents
  "haiku_model": "haiku",         // Default model for haiku-tier agents

  // ── Pipeline cycle limits ──
  "max_design_cycles": 2,         // Max QA review → refine loops in Stage 1
  "max_build_cycles": 3,          // Max build → fix loops per implementation cycle
  "max_impl_cycles": 3,           // Max implementation → review cycles in Stage 2
  "max_pr_cycles": 2,             // Max PR comment → fix cycles in Stage 4

  // ── Orchestration ──
  "orchestration_mode": "orchestrated",     // "pm" = LLM orchestrator (Claude SDK Task tool)
                                  // "orchestrated" = Python-driven loops (supports mixed engines)

  // ── API configuration ──
  "api_base_url": "",             // Custom Anthropic API base URL (e.g. "https://proxy.example.com")
  "copilot_github_token": "",     // GitHub token for Copilot engine (leave empty to use gh CLI auth)

  // ── Per-agent engine & model overrides ──
  // Each agent can use "claude" or "copilot" engine independently.
  // Only "orchestrated" mode supports mixed engines; "pm" mode uses Claude for all agents.
  //
  // model_config.mode:
  //   "simple"   = Subscription (uses built-in API keys)
  //   "advanced" = API / BYOK (requires base_url and api_key)
  //
  // model_config.provider_type (for advanced mode):
  //   "openai" | "azure" | "anthropic" | "bedrock"
  //
  // Available roles: lead-developer, developer, code-reviewer, qa-engineer, build-agent, repo-manager
  "agent_configs": {
    "lead-developer": {
      "engine": "claude",         // "claude" or "copilot"
      "model_config": {
        "mode": "simple",         // "simple" or "advanced"
        "model": "opus",          // Model name (e.g. "opus", "sonnet", "gpt-5.4", "codex")
        "provider_type": "openai",
        "base_url": "",           // Required when mode is "advanced"
        "api_key": "",            // Required when mode is "advanced"
        "extra_params": {}        // Additional provider-specific params (JSON object)
      },
      "mcp_servers": {}           // MCP server configs (name → {command, args, env})
    },
    "developer": {
      "engine": "claude",
      "model_config": {
        "mode": "simple",
        "model": "sonnet"
      },
      "mcp_servers": {}
    },
    "code-reviewer": {
      "engine": "copilot",
      "model_config": {
        "mode": "simple",
        "model": "codex"
      },
      "mcp_servers": {}
    },
    "qa-engineer": {
      "engine": "copilot",
      "model_config": {
        "mode": "simple",
        "model": "gpt-5.4"
      },
      "mcp_servers": {}
    },
    "build-agent": {
      "engine": "copilot",
      "model_config": {
        "mode": "simple",
        "model": "gpt-5-mini"
      },
      "mcp_servers": {}
    },
    "repo-manager": {
      "engine": "copilot",
      "model_config": {
        "mode": "simple",
        "model": "gpt-5-mini"
      },
      "mcp_servers": {}
    }
  }
}
