# Copy this file to .env and fill in your actual values.
# .env is gitignored — your secrets stay off disk and out of history.
# OLamo loads .env automatically at startup, so env:VAR_NAME references
# in olamo-settings.json resolve without any shell-profile edits.

# API key referenced by:  "api_key": "env:OLAMO_ZAI_API_KEY"
OLAMO_ZAI_API_KEY=your-api-key-here

# Add additional keys here as needed, one per model provider / config block.
# ANOTHER_PROVIDER_KEY=sk-...
