{
  "models": {
    "opus": "opus",
    "sonnet": "sonnet",
    "haiku": "haiku",
    "pm": "sonnet"
  },
  "pipeline": {
    "max_design_cycles": 5,
    "max_build_cycles": 3,
    "max_impl_cycles": 5,
    "max_pr_cycles": 3
  },
  "agents": {
    "reviewers": ["qa-engineer", "lead-developer"],
    "default_engines": {
      "lead-developer": "claude",
      "developer":      "claude",
      "code-reviewer":  "copilot",
      "qa-engineer":    "copilot",
      "build-agent":    "copilot",
      "repo-manager":   "copilot"
    },
    "engine_default_models": {
      "lead-developer": { "claude": "opus_model", "copilot": "claude-opus-4-6", "codex": "codex", "openai": "gpt-5.4" },
      "developer":      { "claude": "sonnet_model", "copilot": "claude-sonnet-4-6", "codex": "codex", "openai": "gpt-5.4" },
      "code-reviewer":  { "claude": "opus_model", "copilot": "codex", "codex": "codex", "openai": "gpt-5.4" },
      "qa-engineer":    { "claude": "opus_model", "copilot": "gpt-5.4", "codex": "codex", "openai": "gpt-5.4" },
      "build-agent":    { "claude": "haiku_model", "copilot": "gpt-5-mini", "codex": "codex-mini", "openai": "gpt-5-mini" },
      "repo-manager":   { "claude": "haiku_model", "copilot": "gpt-5-mini", "codex": "codex-mini", "openai": "gpt-5-mini" }
    },
    "tools": {
      "lead-developer": ["Read", "Glob", "Grep", "WebSearch", "WebFetch"],
      "developer":      ["Read", "Write", "Edit", "Bash", "Glob", "Grep"],
      "code-reviewer":  ["Read", "Glob", "Grep"],
      "qa-engineer":    ["Read", "Bash", "Glob", "Grep"],
      "build-agent":    ["Bash", "Read", "Glob"],
      "repo-manager":   ["Bash", "Read"]
    }
  }
}
